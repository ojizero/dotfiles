# Forgejo runner config for the forge stack (DIND sidecar).
#
# 1. Generate a baseline and copy to ${FORGEJO_RUNNER_DATA_PATH}/config.yml:
#      docker run --rm code.forgejo.org/forgejo/runner:12.10.1 \
#        forgejo-runner generate-config > configs/runner/data/config.yml
#    Then merge in the `runner.labels` and `container` sections from this file.
#
# 2. Create a registration token (Site administration → Actions → Runners):
#      docker exec -u git forgejo forgejo actions generate-runner-token
#
# 3. Register once before starting the daemon (use the internal Forgejo URL):
#      docker compose run --rm --no-deps forgejo-runner \
#        forgejo-runner register --config /data/config.yml --no-interactive \
#        --instance http://forgejo:3000 \
#        --token <registration-token> \
#        --name atlas-forgejo-runner
#    Labels are taken from `runner.labels` below, not the CLI `--labels` flag.
#
# 4. Start the stack: docker compose up -d

log:
  level: info
  job_level: info

runner:
  file: .runner
  capacity: 1
  timeout: 3h
  shutdown_timeout: 3h
  insecure: false
  fetch_timeout: 30s
  fetch_interval: 2s
  report_interval: 1s
  labels:
    - "docker:docker://node:22-bookworm"
    - "ubuntu-latest:docker://node:22-bookworm"

cache:
  enabled: true
  port: 0
  dir: ""
  external_server: ""
  secret: ""
  host: ""
  proxy_port: 0

container:
  network: ""
  enable_ipv6: false
  # Required for workflows that run Docker-in-Docker service containers.
  privileged: true
  valid_volumes: []
  docker_host: "-"
  force_pull: false
  force_rebuild: false

host:
  workdir_parent:

server:
  connections:
