# Paths for the data volumes for Forgejo & its runner.
FORGEJO_DATA_PATH=./configs/forgejo/data
FORGEJO_RUNNER_DATA_PATH=./configs/runner/data

# PostgreSQL credentials (also used by Forgejo)
FORGEJO_DB_USER=forgejo
FORGEJO_DB_PASSWORD=

# UID/GID for Forgejo data and runner; must own paths above and configs/postgres
PUID=1000
PGID=1000

# servicenet subnet or Traefik container IP (docker network inspect servicenet)
FORGEJO_REVERSE_PROXY_TRUSTED_PROXIES=172.18.0.0/16

# The secret key used for encryption related loads, 2FA tokens, etc.
FORGEJO_SECRET_KEY=

# Set to true after initial Forgejo setup is complete.
FORGEJO_INSTALL_LOCK=false

# Runner setup (one-time, on Atlas):
# 1. cp config.yml.sample configs/runner/data/config.yml
# 2. docker compose up -d docker-dind forgejo
# 3. Generate token: docker exec -u git forgejo forgejo actions generate-runner-token
# 4. Register: docker compose exec forgejo-runner forgejo-runner register \
#      --config /data/config.yml --no-interactive \
#      --instance https://forge.ojizero.dev --token <token> \
#      --name atlas-forgejo-runner \
#      --labels "docker:docker://node:22-bookworm,ubuntu-latest:docker://node:22-bookworm"
# 5. docker compose up -d forgejo-runner
#
# For local testing without Traefik, use compose.override.yml (gitignored).