# Paths for the data volumes for Forgejo & it's runner.
FORGEJO_DATA_PATH=./configs/forge/data
FORGEJO_RUNNER_DATA_PATH=./configs/forge/runner

# PostgreSQL credentials (also used by Forgejo)
FORGEJO_DB_USER=forgejo
FORGEJO_DB_PASSWORD=

# UID/GID for Forgejo data and runner; must own paths above and configs/postgres
PUID=1000
PGID=1000

# servicenet subnet or Traefik container IP (docker network inspect servicenet)
FORGEJO_REVERSE_PROXY_TRUSTED_PROXIES=172.18.0.0/16

# The secret key used for encryption related loads, 2FA tokens, etc.
FORGEJO_SECRET_KEY=