{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "DISABLE_AUTOUPDATER": "1",
    "ANTHROPIC_BASE_URL": "http://aperture.tn.ojizero.dev",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "openai/gpt-5.6-terra",
    "ANTHROPIC_DEFAULT_OPUS_MODEL_NAME": "GPT 5.6 Terra",
    "ANTHROPIC_DEFAULT_OPUS_MODEL_SUPPORTED_CAPABILITIES": "effort,thinking,adaptive_thinking",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "openai/gpt-5.6-luna",
    "ANTHROPIC_DEFAULT_SONNET_MODEL_NAME": "GPT 5.6 Luna",
    "ANTHROPIC_DEFAULT_SONNET_MODEL_SUPPORTED_CAPABILITIES": "effort,thinking,adaptive_thinking",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "deepseek-ai/DeepSeek-V4-Flash",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL_NAME": "DeepSeek V4 Flash",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL_SUPPORTED_CAPABILITIES": "effort,thinking,adaptive_thinking",
    "ANTHROPIC_DEFAULT_FABLE_MODEL": "openai/gpt-5.6-sol",
    "ANTHROPIC_DEFAULT_FABLE_MODEL_NAME": "GPT 5.6 Sol",
    "ANTHROPIC_DEFAULT_FABLE_MODEL_SUPPORTED_CAPABILITIES": "effort,thinking,adaptive_thinking"
  },
  "permissions": {
    "defaultMode": "default"
  },
  "model": "fable",
  "enabledPlugins": {},
  "alwaysThinkingEnabled": true,
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "theme": "auto",
  "autoCompactEnabled": false,
  "teammateMode": "auto"
}
