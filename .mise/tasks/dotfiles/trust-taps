#!/usr/bin/env zsh
#MISE description="Trust Homebrew taps declared in Brewfile(s)"

for file in "${DOTFILES_PATH}/Brewfile" "${DOTFILES_PATH}/.local/Brewfile"; do
  [[ -f "${file}" ]] || continue

  while IFS= read -r line; do
    if [[ "${line}" =~ '^tap "([^"]+)"' ]]; then
      brew trust --tap "${match[1]}"
    fi
  done < "${file}"
done
