#!/usr/bin/env zsh
#MISE description="Auto-pull on default branch if repo is clean"
#MISE raw=true

CWD="${MISE_ORIGINAL_CWD:-$PWD}"

# Only proceed if we're inside a git repo
git -C "$CWD" rev-parse --is-inside-work-tree > /dev/null 2>&1 || exit 0

# Skip linked worktrees — git-dir and git-common-dir differ in a linked worktree
GIT_DIR=$(git -C "$CWD" rev-parse --git-dir 2>/dev/null)
GIT_COMMON_DIR=$(git -C "$CWD" rev-parse --git-common-dir 2>/dev/null)
[ "$GIT_DIR" != "$GIT_COMMON_DIR" ] && exit 0

# Only proceed if we're at the git root (avoid re-running in subdirs)
GIT_ROOT=$(git -C "$CWD" rev-parse --show-toplevel 2>/dev/null)
[ "$GIT_ROOT" != "$CWD" ] && exit 0

# Only proceed if the repo has a remote
git -C "$CWD" remote | grep -q . || exit 0

# Determine the default branch
DEFAULT_BRANCH=$(git -C "$CWD" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|refs/remotes/origin/||')
[ -z "$DEFAULT_BRANCH" ] && exit 0

# Only proceed if we're on the default branch
CURRENT_BRANCH=$(git -C "$CWD" rev-parse --abbrev-ref HEAD 2>/dev/null)
[ "$CURRENT_BRANCH" != "$DEFAULT_BRANCH" ] && exit 0

# Fetch quietly to update remote tracking info
git -C "$CWD" fetch --quiet origin "$DEFAULT_BRANCH" 2>/dev/null

# Check for unstaged/uncommitted changes
DIRTY=$(git -C "$CWD" status --porcelain 2>/dev/null)

# Check for commits ahead of remote
AHEAD=$(git -C "$CWD" rev-list "@{u}..HEAD" --count 2>/dev/null)

if [ -n "$DIRTY" ]; then
  echo "⚠️  mise: repo has unstaged/uncommitted changes — skipping auto-pull"
elif [ "${AHEAD:-0}" -gt 0 ]; then
  echo "⚠️  mise: repo has $AHEAD commit(s) ahead of remote — skipping auto-pull"
else
  echo "⬇️  mise: pulling latest changes..."
  git -C "$CWD" pull --ff-only --quiet
fi
